tenancy_ocid         = "ocid1.tenancy.oc1..replace_me"
user_ocid            = "ocid1.user.oc1..replace_me"
fingerprint          = "replace:me:with:key:fingerprint"
private_key_path     = "~/.oci/oci_api_key.pem"
region               = "us-ashburn-1"
compartment_ocid     = "ocid1.compartment.oc1..replace_me"
ssh_public_key_path  = "~/.ssh/id_rsa.pub"
ssh_private_key_path = "~/.ssh/id_rsa"

# Strongly recommended: replace this with your workstation public IP /32.
allowed_ssh_cidr = "203.0.113.10/32"

# Address pool split into one /20 VCN and one /24 subnet per isolated lab.
# Keep this as a /16 unless you also revise the CIDR calculations in main.tf.
vcn_cidr = "10.77.0.0/16"

# Selects the newest standard Oracle Linux 10 platform image compatible with
# each shape. E6 and E6.Ax (AMD Acceleron) are both x86_64 shapes.
oracle_linux_major_version = "10"

# This deploys 16 instances total. Every shape gets a dedicated client/target,
# VCN, and subnet for each mode: iptables, nftables, xdp-generic, xdp-native.
#   e6:    4 isolated labs x 2 instances
#   e6_ax: 4 isolated labs x 2 instances
# Every instance is locked to 10 OCPUs and 80 GB RAM.
benchmark_shapes = {
  e6 = {
    shape         = "VM.Standard.E6.Flex"
    ocpus         = 10
    memory_in_gbs = 80
  }
  e6_ax = {
    shape         = "VM.Standard.E6.Ax.Flex"
    ocpus         = 10
    memory_in_gbs = 80
  }

  # Optional: uncomment if you also want to keep the old E4 baseline in the same run.
  # e4 = {
  #   shape         = "VM.Standard.E4.Flex"
  #   ocpus         = 10
  #   memory_in_gbs = 80
  # }
}
